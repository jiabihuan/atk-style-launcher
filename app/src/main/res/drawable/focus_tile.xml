<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="14dp" />
            <solid android:color="#42FFFFFF" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFFFF" />
            <padding
                android:left="10dp"
                android:top="10dp"
                android:right="10dp"
                android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="14dp" />
            <solid android:color="#26101820" />
            <stroke
                android:width="1dp"
                android:color="#18FFFFFF" />
        </shape>
    </item>
</selector>
